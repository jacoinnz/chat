datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id               String        @id @default(cuid())
  tenantId         String        @unique // Azure AD tenant GUID
  name             String        @default("")
  onboardingStatus String        @default("setup_pending") // "setup_pending" | "setup_complete"
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  config           TenantConfig?
  aiProvider       AIProviderConfig?
  usageLogs        UsageLog[]
}

model AIProviderConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  provider        String   @default("anthropic")   // "anthropic" | "openai" | "azure_openai"
  modelId         String   @default("claude-sonnet-4-20250514")
  keySource       String   @default("platform")    // "platform" | "keyvault"
  encryptedKey    String?                           // AES-256-GCM encrypted API key (platform mode)
  keyVaultUrl     String?                           // e.g. https://myvault.vault.azure.net
  keyVaultSecret  String?                           // secret name in Key Vault
  azureEndpoint   String?                           // Azure OpenAI endpoint (provider=azure_openai only)
  azureDeployment String?                           // Azure OpenAI deployment name
  temperature     Float    @default(0.3)
  maxTokens       Int      @default(1024)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TenantConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  taxonomy        Json     // { department: string[], sensitivity: string[], status: string[] }
  contentTypes    Json     // string[]
  kqlPropertyMap  Json     // Record<string, string>
  searchFields    Json     // string[]
  keywords        Json     // Array<{ term: string, synonyms: string[] }>
  reviewPolicies  Json     // Array<{ contentType: string, maxAgeDays: number, warningDays: number }>
  searchBehaviour Json     // { approvedOnly: boolean, hideRestricted: boolean, maxResults: number, recencyBoostDays: number, recencyWeight: number, matchWeight: number, freshnessWeight: number }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UsageLog {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  event        String   // "search" | "chat" | "error" | "no_results" | "graph_error" | "auth_error"
  userHash     String   // SHA-256 of Azure AD OID
  errorCode    String?
  resultCount  Int?     // Number of search results returned
  query        String?  // Sanitised query (no PII — only intent keywords)
  filtersUsed  String?  // JSON string of filter keys used (not values)
  intentType   String?  // Detected intent type
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, event])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userHash  String   // SHA-256 of admin's Azure AD OID
  action    String   // "update" | "reset"
  section   String   // "taxonomy" | "content-types" | "keywords" | "review-policies" | "search-behaviour" | "kql-map" | "search-fields" | "config"
  details   String?  // Human-readable summary of the change
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

model ConfigVersion {
  id          String    @id @default(cuid())
  tenantId    String
  version     Int
  status      String    @default("published") // "published" | "draft"
  snapshot    Json      // full config: all 7 sections
  section     String    // what triggered it: "taxonomy" | "content-types" | ... | "rollback" | "reset"
  authorHash  String
  authorName  String    @default("")
  comment     String?
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  @@unique([tenantId, version])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model AdminRole {
  id         String   @id @default(cuid())
  tenantId   String
  userHash   String   // SHA-256 of Azure AD OID
  role       String   // "platform_admin" | "config_admin" | "auditor" | "viewer"
  assignedBy String   // SHA-256 of assigner's OID
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, userHash])
  @@index([tenantId])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  enabled     Boolean  @default(false)
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Feedback {
  id           String   @id @default(cuid())
  tenantId     String
  messageId    String
  userHash     String   // SHA-256 of Azure AD OID
  feedbackType String   // "thumbs_up" | "thumbs_down" | "report"
  comment      String?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
}

model UsageDailySummary {
  id            String   @id @default(cuid())
  tenantId      String
  date          String   // ISO date string "YYYY-MM-DD"
  searchCount   Int      @default(0)
  chatCount     Int      @default(0)
  errorCount    Int      @default(0)
  noResultCount Int      @default(0)
  activeUsers   Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([tenantId, date])
}

model SavedQuery {
  id        String   @id @default(cuid())
  tenantId  String
  userHash  String   // SHA-256 of Azure AD OID
  title     String
  query     String
  filters   Json?    // MetadataFilters snapshot
  createdAt DateTime @default(now())

  @@index([tenantId, userHash])
}

model Favorite {
  id          String   @id @default(cuid())
  tenantId    String
  userHash    String   // SHA-256 of Azure AD OID
  documentUrl String
  title       String
  siteName    String   @default("")
  metadata    Json?    // Additional document metadata
  createdAt   DateTime @default(now())

  @@unique([tenantId, userHash, documentUrl])
}

model RecentSearch {
  id          String   @id @default(cuid())
  tenantId    String
  userHash    String   // SHA-256 of Azure AD OID
  query       String
  filters     Json?    // MetadataFilters snapshot
  resultCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([tenantId, userHash, createdAt])
}

model DiscoveredProperty {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  type          String
  searchable    Boolean  @default(false)
  queryable     Boolean  @default(true)
  retrievable   Boolean  @default(false)
  refinable     Boolean  @default(false)
  mappings      String?
  lastScrapedAt DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
}

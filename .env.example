# Azure AD / Entra ID App Registration
NEXT_PUBLIC_AZURE_CLIENT_ID=your-client-id-here
NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000

# Anthropic Claude API (server-only)
ANTHROPIC_API_KEY=sk-ant-...

# Turso Database (admin portal)
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# App environment label (shown in header)
NEXT_PUBLIC_APP_ENV=Dev

# Cron job authentication (optional — required for /api/cron/* endpoints)
CRON_SECRET=your-cron-secret-here
